<script>
var CONFIG = {"fromUnit": "Bigha", "toUnit": "Acre", "fromSqft": {"pucca": 27225, "kaccha": 9075, "wb": 14400}, "toSqft": 43560, "shareText": "Bigha to Acre conversion yahan check karein: https://zameennaplo.in/bigha-to-acre/"};
var reversed=false;
var typeEl=document.getElementById("unitType");
var inputEl=document.getElementById("inputValue");
var swapBtn=document.getElementById("swapBtn");
var inputLabel=document.getElementById("inputLabel");
var resultLabel=document.getElementById("resultLabel");
var resultMain=document.getElementById("resultMain");
var resultExtra=document.getElementById("resultExtra");
function fmt(n){return n.toLocaleString("en-IN",{maximumFractionDigits:4});}
function fromSqftVal(){
  if(typeof CONFIG.fromSqft==="object"){return CONFIG.fromSqft[typeEl.value];}
  return CONFIG.fromSqft;
}
function convert(){
  var val=parseFloat(inputEl.value);
  if(isNaN(val)||val<0){resultMain.textContent="—";resultExtra.textContent="Sahi value daalein";return;}
  var f=fromSqftVal(),sqft,out;
  if(!reversed){sqft=val*f;out=sqft/CONFIG.toSqft;resultMain.textContent=fmt(out)+" "+CONFIG.toUnit;}
  else{sqft=val*CONFIG.toSqft;out=sqft/f;resultMain.textContent=fmt(out)+" "+CONFIG.fromUnit;}
  var sqm=sqft*0.092903;
  resultExtra.textContent="= "+fmt(sqft)+" sq ft = "+fmt(sqm)+" sq meter";
}
function setDirection(){
  if(!reversed){
    inputLabel.textContent=CONFIG.fromUnit+" me value daalein";
    resultLabel.textContent="Result ("+CONFIG.toUnit+" me)";
    swapBtn.textContent="\u21c4 Ulta convert karein ("+CONFIG.toUnit+" \u2192 "+CONFIG.fromUnit+")";
  }else{
    inputLabel.textContent=CONFIG.toUnit+" me value daalein";
    resultLabel.textContent="Result ("+CONFIG.fromUnit+" me)";
    swapBtn.textContent="\u21c4 Ulta convert karein ("+CONFIG.fromUnit+" \u2192 "+CONFIG.toUnit+")";
  }
  convert();
}
swapBtn.addEventListener("click",function(){reversed=!reversed;setDirection();});
inputEl.addEventListener("input",convert);
if(typeEl){typeEl.addEventListener("change",convert);}
document.getElementById("waShare").href="https://wa.me/?text="+encodeURIComponent(CONFIG.shareText);
setDirection();
</script>
